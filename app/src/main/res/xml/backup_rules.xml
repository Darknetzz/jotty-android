<?xml version="1.0" encoding="utf-8"?>
<!-- Exclude sensitive data from Android auto backup (API 23+). -->
<full-backup-content>
    <exclude domain="sharedpref" path="jotty_api_keys.xml" />
    <exclude domain="sharedpref" path="jotty_biometric_passphrases.xml" />
    <exclude domain="file" path="datastore/jotty_settings.preferences_pb" />
    <exclude domain="database" path="jotty_database" />
    <exclude domain="database" path="jotty_database-shm" />
    <exclude domain="database" path="jotty_database-wal" />
</full-backup-content>
