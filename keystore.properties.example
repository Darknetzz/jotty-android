# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored — it will not be committed.
#
# 1. Create a keystore (one-time; keep the file and passwords safe forever):
#    keytool -genkey -v -keystore jotty-release.keystore -alias jotty -keyalg RSA -keysize 2048 -validity 10000
#
# 2. Put the path to the keystore file (relative to project root) and your passwords below.

storeFile=jotty-release.keystore
storePassword=your-keystore-password
keyAlias=jotty
keyPassword=your-key-password

# --- GitHub Releases (fixes in-place updates; see issue #9) ---
#
# Use the SAME keystore for every release. Add these repository secrets
# (Settings → Secrets and variables → Actions):
#
#   ANDROID_KEYSTORE_B64      base64 of the .jks/.keystore file
#   ANDROID_KEYSTORE_PASSWORD store password
#   ANDROID_KEY_ALIAS         key alias (e.g. jotty)
#   ANDROID_KEY_PASSWORD      key password
#
# Encode the keystore (Linux/macOS/Git Bash):
#   base64 -w0 jotty-release.keystore   # Linux
#   base64 -i jotty-release.keystore    # macOS
#
# PowerShell:
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("jotty-release.keystore"))
#
# When all four secrets are set, the release-apk workflow attaches
# jotty-android-{version}.apk (release-signed, minified). Without secrets,
# only a debug-signed APK is attached and updates may conflict across builds.
